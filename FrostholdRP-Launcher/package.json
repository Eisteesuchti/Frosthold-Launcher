{
  "name": "frostholdrp-launcher",
  "version": "0.2.11",
  "description": "FrostholdRP Skyrim Multiplayer Launcher",
  "author": "FrostholdRP",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "clean:dist": "node scripts/clean-dist.mjs",
    "prepare-runtime": "node scripts/prepare-python-runtime.mjs",
    "prepare-7zr": "node scripts/prepare-7zr.mjs",
    "prepare-vcredist": "node scripts/prepare-vcredist.mjs",
    "prepare-all": "npm run prepare-runtime && npm run prepare-7zr && npm run prepare-vcredist",
    "pack": "npm run clean:dist && npm run prepare-all && electron-builder --win portable --x64",
    "installer": "npm run clean:dist && npm run prepare-all && electron-builder --win nsis --x64",
    "dist": "npm run clean:dist && npm run prepare-all && electron-builder --win nsis portable --x64",
    "dist:installer": "npm run clean:dist && npm run prepare-all && electron-builder --win nsis --x64",
    "dist:portable": "npm run clean:dist && npm run prepare-all && electron-builder --win portable --x64",
    "dist:publish": "npm run clean:dist && npm run prepare-all && electron-builder --win nsis --x64 --publish always",
    "release": "node scripts/release-launcher.mjs"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.frostholdrp.launcher",
    "productName": "FrostholdRP Launcher",
    "directories": {
      "output": "dist-build"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "assets/**/*",
      "news.json",
      "launcher-bundled-defaults.json",
      "frosthold-manifest.json"
    ],
    "extraResources": [
      {
        "from": "../FrostMP-Launcher.py",
        "to": "."
      },
      {
        "from": "../frostmp_core.py",
        "to": "."
      },
      {
        "from": "../frostmp_gui.py",
        "to": "."
      },
      {
        "from": "launcher-bundled-defaults.json",
        "to": "."
      },
      {
        "from": "python-runtime",
        "to": "python-runtime"
      },
      {
        "from": "bin",
        "to": "bin"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerLanguages": [
        "de_DE",
        "en_US"
      ],
      "language": "1031",
      "include": "build/nsis-installer.nsh",
      "runAfterFinish": true,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "shortcutName": "FrostholdRP Launcher",
      "uninstallDisplayName": "FrostholdRP Launcher",
      "artifactName": "Frosthold-Installer-${version}.${ext}"
    },
    "portable": {
      "artifactName": "FrostholdRP-Launcher-${version}-portable.exe"
    },
    "publish": {
      "provider": "github",
      "owner": "Eisteesuchti",
      "repo": "Frosthold-Launcher",
      "releaseType": "release"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
